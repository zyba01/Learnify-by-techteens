{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and their role (student, teacher, admin).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "admin"] },
        "class": { "type": "string", "description": "Assigned class for students (e.g., 11 'A')" }
      },
      "required": ["uid", "email", "role"]
    },
    "Grade": {
      "title": "Grade",
      "description": "Academic grade for a student in a specific subject and quarter.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "UID of the student" },
        "subject": { "type": "string" },
        "quarter": { "type": "integer", "enum": [1, 2, 3, 4] },
        "value": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string", "description": "UID of the teacher/admin who set the grade" }
      },
      "required": ["studentId", "subject", "quarter", "value", "updatedAt", "updatedBy"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance record for a student.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["present", "absent", "late"] }
      },
      "required": ["studentId", "date", "status"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Logs of when grades or other sensitive data are changed.",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "performedBy": { "type": "string" },
        "targetId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": { "type": "string" }
      },
      "required": ["action", "performedBy", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles and roles."
    },
    "/grades/{gradeId}": {
      "schema": "Grade",
      "description": "Academic grades."
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance records."
    },
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "System audit logs."
    }
  }
}
